name: bruin-init
schedule: daily
start_date: "2026-03-31"
catchup: false

default_connections:
  google_cloud_platform: "gcp_conn"

variables:
  GCP_PROJECT_ID:
    type: string
    default: "aml-dash-8888"
  BQ_DATASET:
    type: string
    default: "aml_bq"
  GCP_BUCKET:
    type: string
    default: "aml-pmg-bucket"
  DATASET_SIZE:
      type: string
      default: "small" # Options: Small, Medium, Large, can ovverride with --var dataset_size=Medium