# .env-template

# Google Cloud Authentication
# GOOGLE_APPLICATION_CREDENTIALS must be an ABSOLUTE path
export GOOGLE_APPLICATION_CREDENTIALS=""
# BRUIN_GCP_KEY must be a RELATIVE path from project root
export BRUIN_GCP_KEY=""

# Project Resources
export GCP_PROJECT_ID=""
export GCP_BUCKET=""
export BQ_DATASET=""

# Data ingestion (Kaggle)
# Format: '{"username":"your_user","key":"your_key"}'
export KAGGLE_API_TOKEN=''